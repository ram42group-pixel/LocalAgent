# LocalAgent 環境変数テンプレート / Environment variable template
# このファイルを .env にコピーして、使うプロバイダのキーだけ設定してください。
# Copy this file to .env and fill in only the keys for providers you use.
#
#   cp .env.example .env
#
# ※ .env は .gitignore で除外されます。絶対にコミットしないでください。
#    .env is gitignored. Never commit it.

# === LLMプロバイダ（少なくとも1つ。ローカルのollamaはキー不要）===
# === LLM providers (at least one; local ollama needs no key) ===

# Groq（複数キーでレート制限を分散可 / multiple keys for rate-limit spreading）
GROQ_API_KEY1=
GROQ_API_KEY2=

# Cerebras（注: コード内の綴りは CREBRAS / note the spelling in code）
CREBRAS_API_KEY=

# Google AI Studio (Gemini)
GOOGLE_API_KEY2=

# OpenRouter
OPEN_ROUTER_API_KEY=

# Mistral
MISTRAL_API_KEY=

# === Web検索（任意 / optional）===
# Tavily: DuckDuckGo/Bingが403等で使えない時の安定した検索バックエンド
# Tavily: stable search backend when DuckDuckGo/Bing return 403 etc.
TAVILY_API_KEY=

# NVD（CVE照合の安定化 / stabilizes CVE lookups）
NVD_API_KEY=

# === 動作設定（任意 / optional behavior flags）===
# 1 にするとクラウドを使わずローカルollamaのみで動作
# Set to 1 to run fully local (ollama only, no cloud)
# AGENT_OFFLINE=0
